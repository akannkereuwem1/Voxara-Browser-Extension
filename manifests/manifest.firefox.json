{
  "manifest_version": 2,
  "name": "Voxara",
  "version": "0.1.0",
  "description": "Transform PDFs into an interactive audio-first reading experience",
  "permissions": ["storage", "activeTab", "scripting", "alarms", "<all_urls>"],
  "background": {
    "scripts": ["src/background/index.js"],
    "persistent": false
  },
  "browser_action": {},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "src/options/index.html"
  }
}
